# ═══════════════════════════════════════════════════
# SPICK .gitignore
# ═══════════════════════════════════════════════════

# Känslig data — ALDRIG i git
SESSION_HANDOFF.md
backups/
*.env
.env.*
secrets.json

# Byggfiler
node_modules/
dist/
.cache/
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db
*.swp
*~

# IDE
.vscode/
.idea/
.claude/*
!.claude/settings.json

# Lokal CLI-state + backups (aldrig i git)
supabase/.temp/
*.bak
*.local

# Temporärt
*.log
*.tmp
node_modules/
test-results/
playwright-report/

# Lokal automationsagent — körs lokalt, inte en del av webbplatsen
agent/

# Lokala DB-backups — innehåller PII, ska aldrig committas
backups/
fix*.js
search-dashboard.js

# prod-schema.sql — baseline-snapshot för schema-drift-check (H19-fix).
# TILLÅTS nu i repo (tidigare gitignore'd). Uppdateras via workflow
# `bootstrap-prod-schema.yml` + schema-drift-check committar automatiskt.
#
# MEN: ad-hoc backup-snapshots (med datum eller "backup" i namnet) är
# känsliga och får ALDRIG committas — kan innehålla PII/credentials.
prod-schema-*-backup.sql
prod-backup-*.sql
*-prod-backup.sql

# Claude Code local config
.agents/
skills-lock.json

# k6 load-test results (ephemeral, regenereras per körning)
tests/load/latest-result.json
tests/load/summary.json

# Supabase CLI branch-state (ej i git per default)
supabase/.branches/

# Investor-material (KONFIDENTIELLT — aldrig committas till public repo)
# Innehåller värderingsindikationer, use of proceeds, risker, jämförbara.
# Filer genereras lokalt via docs/investor/generate-deck.py vid behov.
docs/investor/
