<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#085041"/>
      <stop offset="100%" stop-color="#0F6E56"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <!-- Dekorativa cirklar -->
  <circle cx="1050" cy="100" r="200" fill="rgba(255,255,255,0.04)"/>
  <circle cx="150" cy="530" r="160" fill="rgba(255,255,255,0.04)"/>
  <circle cx="1100" cy="550" r="120" fill="rgba(255,255,255,0.03)"/>
  <!-- Logo -->
  <text x="100" y="180" font-family="Georgia, serif" font-size="96" font-weight="700" fill="white">Spick</text>
  <!-- Tagline -->
  <text x="100" y="270" font-family="Arial, sans-serif" font-size="42" font-weight="300" fill="rgba(255,255,255,0.85)">Boka en städare du verkligen litar på</text>
  <!-- Stats -->
  <rect x="100" y="350" width="280" height="120" rx="16" fill="rgba(255,255,255,0.12)"/>
  <text x="240" y="400" text-anchor="middle" font-family="Georgia, serif" font-size="48" font-weight="700" fill="white">50%</text>
  <text x="240" y="440" text-anchor="middle" font-family="Arial, sans-serif" font-size="20" fill="rgba(255,255,255,0.75)">billigare med RUT</text>
  
  <rect x="420" y="350" width="280" height="120" rx="16" fill="rgba(255,255,255,0.12)"/>
  <text x="560" y="400" text-anchor="middle" font-family="Georgia, serif" font-size="48" font-weight="700" fill="white">4.9 ★</text>
  <text x="560" y="440" text-anchor="middle" font-family="Arial, sans-serif" font-size="20" fill="rgba(255,255,255,0.75)">snittbetyg</text>
  
  <rect x="740" y="350" width="280" height="120" rx="16" fill="rgba(255,255,255,0.12)"/>
  <text x="880" y="400" text-anchor="middle" font-family="Georgia, serif" font-size="48" font-weight="700" fill="white">2 min</text>
  <text x="880" y="440" text-anchor="middle" font-family="Arial, sans-serif" font-size="20" fill="rgba(255,255,255,0.75)">boka online</text>
  <!-- URL -->
  <text x="100" y="580" font-family="Arial, sans-serif" font-size="26" fill="rgba(255,255,255,0.5)">spick.se</text>
</svg>