{
  "name": "spick-agent",
  "version": "1.2.0",
  "description": "Local automation agent for spick.se – controls Microsoft Edge via Playwright",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "wizard": "node scripts/setup-wizard.js",
    "setup": "npm install && npx playwright install msedge && node scripts/setup-wizard.js",
    "test-task": "node scripts/test-trigger.js",
    "tunnel": "node scripts/setup-tunnel.js",
    "tunnel:named": "node scripts/setup-tunnel.js named",
    "shortcuts": "node scripts/generate-shortcuts.js",
    "install-browsers": "npx playwright install msedge"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "playwright": "^1.49.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
